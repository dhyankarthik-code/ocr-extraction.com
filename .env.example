# ──────────────────────────────────────────────────────────────────────────────
# INFYGALAXY - FULL SYSTEM RECOVERY BLUEPRINT
# Documentation: https://www.ocr-extraction.com
# ──────────────────────────────────────────────────────────────────────────────

# 1. DATABASE (PostgreSQL)
# Required for user persistence, chat history, and analytics.
DATABASE_URL="postgresql://user:password@localhost:5432/ocr?schema=public"

# 2. AI & CORE ENGINES
# Required for OCR processing and AI reports.
MISTRAL_API_KEY="your_mistral_api_key_here"
GOOGLE_CLOUD_API_KEY="your_google_cloud_api_key_here"

# 3. AUTHENTICATION (Google OAuth)
# Required for user login.
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# 4. RATE LIMITING & CACHING (Upstash Redis)
# Recommended for production high-load stability.
UPSTASH_REDIS_URL="your_upstash_redis_url_here"
UPSTASH_REDIS_TOKEN="your_upstash_redis_token_here"

# 5. ASYNC WORKFLOWS (Inngest)
# Used for background task orchestration.
INNGEST_EVENT_KEY="your_inngest_event_key_here"
INNGEST_SIGNING_KEY="your_inngest_signing_key_here"

# 6. EMAIL SERVICE (Resend)
# Used for lead notifications and contact submissions.
RESEND_API_KEY="re_your_api_key"

# 7. SECURITY (reCAPTCHA v3)
# Protects forms from bot spam.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your_public_site_key"
RECAPTCHA_SECRET_KEY="your_private_secret_key"

# 8. APP CONFIG
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
